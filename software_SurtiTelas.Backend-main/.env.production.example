# Backend - Producción
NODE_ENV=production
PORT=3000

# Base de datos (producción)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public

# Redis (producción)
REDIS_URL=redis://HOST:6379

# JWT (mínimo 32 caracteres, aleatorios y diferentes entre sí)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TTL=15m
REFRESH_TTL=7d

# CORS (dominio(s) productivo(s), separados por coma)
CORS_ORIGIN=https://surtitelas.com,https://www.surtitelas.com

# Rate limit
RATE_LIMIT_MAX=300

# Métricas (si aplica)
METRICS_SECRET=
METRICS_ALLOWED_IPS=

# Eventos
EVENT_BUS=redis

# Logs
LOG_LEVEL=info

# SMTP (producción)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SurtiTelas
SMTP_FROM_EMAIL=
