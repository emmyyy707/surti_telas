import { Request, Response } from "express";
import { authUseCase } from "../../../shared/dependencies.js";
import { validateFields, ValidationError } from "../../../shared/validation.js";
import { respuestaBadRequest, respuestaConflict, respuestaUnauthorized, respuestaForbidden } from "../../../shared/http.js";
import { authRegisterSchema } from "../../../shared/validationSchemas.js";

function buildApiUser(user: any) {
  return {
    id: String(user.id_user),
    email: user.email,
    role: user.role,
    name: user.nombre ? String(user.nombre) : [user.name, user.last_name].filter(Boolean).join(" "),
  };
}

export async function login(req: Request, res: Response): Promise<Response> {
  const { email, password } = req.body;
  const validationErrors: ValidationError[] = validateFields(req.body, {
    email: { required: true, max: 100, pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/ },
    password: { required: true, min: 8, max: 128 },
  });
  if (validationErrors.length) {
    return respuestaBadRequest(res, "Validación de campos fallida", validationErrors);
  }

  const result = await authUseCase.login(email, password);
  if (!result) {
    return respuestaUnauthorized(res, "Credenciales inválidas");
  }

  return res.status(200).json({
    accessToken: result.token,
    user: buildApiUser(result.user),
  });
}

export async function register(req: Request, res: Response): Promise<Response> {
  const { nombre, email, password, confirmPassword } = req.body;
  const validationErrors: ValidationError[] = validateFields(req.body, authRegisterSchema);
  if (validationErrors.length) {
    return respuestaBadRequest(res, "Validación de campos fallida", validationErrors);
  }

  if (password !== confirmPassword) {
    return respuestaBadRequest(res, "La confirmación de contraseña no coincide");
  }

  const names = nombre.trim().split(" ");
  const name = names.shift() || "";
  const last_name = names.join(" ") || "";

  if (!name || !last_name) {
    return respuestaBadRequest(res, "Nombre completo debe incluir nombre y apellido");
  }

  const result = await authUseCase.register({
    name,
    last_name,
    email,
    password,
    phone: null,
    address: null,
  });

  if (!result) {
    return respuestaConflict(res, "El correo ya está registrado");
  }

  return res.status(201).json({
    status: "success",
    message: "Registro creado. Debes verificar tu correo antes de iniciar sesión.",
    user: {
      id: result.user.id_user,
      email: result.user.email,
      role: result.user.role,
      name: result.user.name,
    },
  });
}

export async function refresh(req: Request, res: Response): Promise<Response> {
  const { refreshToken } = req.body;
  if (!refreshToken) {
    return respuestaBadRequest(res, "refreshToken es requerido");
  }

  const result = await authUseCase.refreshToken(refreshToken);
  if (!result) {
    return respuestaUnauthorized(res, "Refresh token inválido");
  }

  return res.status(200).json({
    accessToken: result.token,
    user: buildApiUser(result.user),
  });
}

export async function me(req: Request, res: Response): Promise<Response> {
  const user = (req as any).user;
  if (!user) return respuestaUnauthorized(res, "No autorizado");
  return res.status(200).json(buildApiUser(user));
}

export async function requestPasswordReset(req: Request, res: Response): Promise<Response> {
  const { email } = req.body;
  const user = await prisma.users.findUnique({ where: { email: String(email).toLowerCase() } });
  if (!user) {
    return res.status(200).json({ status: "success", message: "Si el correo existe, recibirás instrucciones" });
  }

  const token = randomUUID();
  await prisma.users.update({
    where: { id_user: user.id_user },
    data: {
      password_reset_token: token,
      password_reset_expires: new Date(Date.now() + 1000 * 60 * 60),
    },
  });

  return res.status(200).json({ status: "success", message: "Si el correo existe, recibirás instrucciones" });
}

export async function resetPassword(req: Request, res: Response): Promise<Response> {
  const { token, password } = req.body;
  const user = await prisma.users.findFirst({ where: { password_reset_token: String(token) } });
  if (!user || !user.password_reset_expires || user.password_reset_expires < new Date()) {
    return respuestaBadRequest(res, "Token inválido o expirado");
  }

  const hashedPassword = await bcrypt.hash(password, 12);
  await prisma.users.update({
    where: { id_user: user.id_user },
    data: {
      password: hashedPassword,
      password_reset_token: null,
      password_reset_expires: null,
    },
  });

  return res.status(200).json({ status: "success", message: "Contraseña restaurada correctamente" });
}

export async function verifyEmail(req: Request, res: Response): Promise<Response> {
  const { token } = req.body;
  const user = await prisma.users.findFirst({ where: { email_verification_token: String(token) } });
  if (!user) {
    return respuestaBadRequest(res, "Token de verificación inválido");
  }

  await prisma.users.update({
    where: { id_user: user.id_user },
    data: {
      email_verified: true,
      email_verification_token: null,
    },
  });

  return res.status(200).json({ status: "success", message: "Correo verificado correctamente" });
}

export async function logout(_req: Request, res: Response): Promise<Response> {
  return res.status(200).json({ status: "success", success: true });
}

